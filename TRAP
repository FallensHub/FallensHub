local games = {
    [1784707649939] = "https://raw.githubusercontent.com/FallensHub/FallensHub/refs/heads/main/GKRN.txt", -- gkrn
    [6739698191] = "https://raw.githubusercontent.com/FallensHub/FallensHub/refs/heads/main/VD.FREE.txt" -- vd
}

local StarterGui = game:GetService("StarterGui")
local gameId = game.GameId

local function notify(title, text, duration)
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = title,
            Text = text,
            Duration = duration or 5
        })
    end)
end

if games[gameId] then
    notify("Fallens Notification", "Supported Games! Loadinggg....", 5)
    task.wait(1)
    loadstring(game:HttpGet(games[gameId]))()
else
    notify("Fallens Notification", "Unsupport Games! Sorry....", 5)
end
